# 国内网络环境配置 - Unsloth CN
# China Network Environment Configuration for Unsloth CN
# Usage: source .env.china

export HF_ENDPOINT=https://hf-mirror.com
export UNSLOTH_PYTORCH_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/pytorch-wheels
export PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
export PIP_TRUSTED_HOST=mirrors.aliyun.com
